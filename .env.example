# Copy to .env and edit. Real .env is gitignored.

SUBMIT_URL=https://www.markwork.com/submit
ATTACHMENT_PATH=test_submission.pdf

# Selectors (defaults are best-guesses; refine with: python inspect_submit_page.py)
FILE_INPUT_SELECTOR=input[type=file]
SUBMIT_BUTTON_SELECTOR=button:has-text("Submit")
GRADE_SELECTOR=

# Wait up to this many seconds for the grade to appear after submitting
SUBMIT_TIMEOUT_SECONDS=120

# Google Chat space to alert on failure (matches send_morning.py)
CHAT_SPACE=spaces/AAQAEKYlR3E
